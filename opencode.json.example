{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "cascade-master": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cascade Master",
      "options": {
        "baseURL": "http://localhost:3001/api",
        "headers": {
          "X-API-Key": "your-cascade-api-key"
        }
      },
      "models": {
        "cascade": {
          "name": "Cascade Engine (Auto-Routing)"
        }
      }
    }
  }
}
