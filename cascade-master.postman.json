{
  "info": {
    "name": "Cascade Master API",
    "description": "API collection for Cascade Master - Universal AI Traffic Controller\n\nBase URL: http://localhost:3001\n\nAuthentication: Add X-API-Key header to all requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-API-Key", "type": "string" },
      { "key": "value", "value": "cascade-master-default-key-2026", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Cascade - Send Request",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, what can you do?\"\n    }\n  ],\n  \"stream\": false\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/api/cascade", "host": ["{{baseUrl}}"], "path": ["api", "cascade"] }
      }
    },
    {
      "name": "Cascade - Streaming",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a poem about AI\"\n    }\n  ],\n  \"stream\": true\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/api/cascade", "host": ["{{baseUrl}}"], "path": ["api", "cascade"] }
      }
    },
    {
      "name": "Cascade - Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/cascade", "host": ["{{baseUrl}}"], "path": ["api", "cascade"] }
      }
    },
    {
      "name": "OpenAI Compatible",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"any\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello!\"\n    }\n  ]\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/api/chat/completions", "host": ["{{baseUrl}}"], "path": ["api", "chat", "completions"] }
      }
    },
    {
      "name": "Providers - List",
